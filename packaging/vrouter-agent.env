# vrouter-agent configuration
# Edit this file and run: systemctl restart vrouter-agent

# AgentService address (required)
# Example: AGENT_ARGS="--server 172.30.0.40:30051"
# Example with init config: AGENT_ARGS="--server 172.30.0.40:30051 --init-config /etc/vrouter-agent/init-config.yaml"
AGENT_ARGS="--server 127.0.0.1:30051"

# VRF name to run agent inside (leave empty to disable)
# Example: VRF_NAME=mgmt
VRF_NAME=
